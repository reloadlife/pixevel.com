# Copy to deploy/secrets.env and fill in. deploy/secrets.env is gitignored.
# Uploaded to the server as /opt/pixevel/.env.production (mode 600).
#
# Generate the two crypto keys with:
#   openssl rand -hex 32
#
# REQUIRED ----------------------------------------------------------------------
NODE_ENV=production

# Must match PIXEVEL_DB_PASSWORD you pass to pyinfra. localhost = Postgres on the box.
DATABASE_URL=postgres://pixevel:CHANGE_ME_DB_PASSWORD@localhost:5432/pixevel

# 32-byte hex. Signs sessions + OTP HMAC. Losing/rotating it logs everyone out.
SESSION_SECRET=

# Public origin for payment callbacks / canonical URLs.
# Use the DIRECT domain (.com) here — payment gateways POST back to this, and the
# ArvanCloud CDN in front of .ir can cache/alter POSTs. .ir still serves the site.
APP_BASE_URL=https://pixevel.com
NEXT_PUBLIC_SITE_URL=https://pixevel.com

# Comma-separated admin phone numbers that get the ADMIN role on login.
PIXEVEL_ADMIN_PHONES=09120000000

# OPTIONAL — integrations (leave blank to disable; app degrades gracefully) ------

# OTP via Kavenegar — verify/lookup. Powers BOTH SMS and voice ("call me the code",
# type=call). Register an OTP template in the Kavenegar panel (approved for sms + call)
# and put its name in KAVENEGAR_OTP_TEMPLATE. Set the token, then OTP_DEBUG_LOG=0.
KAVENEGAR_TOKEN=
KAVENEGAR_SENDER=
KAVENEGAR_OTP_TEMPLATE=

# Telegram OTP fallback
TELEGRAM_LOGIN_OTP_BOT_TOKEN=
TELEGRAM_LOGIN_OTP_CHAT_ID=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# Currency fallbacks (admin exchange-rate UI overrides these once set)
SPACESHIP_USD_TO_TOMAN=170000
EUR_TO_TOMAN=200000

# Payments — fill the providers you use
ZARINPAL_MERCHANT_ID=
ZARINPAL_ACCESS_TOKEN=
ZARINPAL_SANDBOX=false
SAMAN_TERMINAL_ID=
BEHPARDAKHT_TERMINAL_ID=
BEHPARDAKHT_USERNAME=
BEHPARDAKHT_PASSWORD=
DIGIPAY_CLIENT_ID=
DIGIPAY_CLIENT_SECRET=
DIGIPAY_USERNAME=
DIGIPAY_PASSWORD=
SNAPPPAY_CLIENT_ID=
SNAPPPAY_CLIENT_SECRET=
SNAPPPAY_USERNAME=
SNAPPPAY_PASSWORD=
CARD_TO_CARD_NUMBER=
CARD_TO_CARD_HOLDER=

# Domains (Spaceship) — until the DB-registrar refactor lands
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=
SPACESHIP_CONTACT_ID=

# Server provisioning upstream (optional)
SERVER_PROVIDER_API_URL=
SERVER_PROVIDER_API_KEY=

# Staging only: log plaintext OTP to the service journal (journalctl -u pixevel | grep otp).
# Turn OFF once real SMS works.
OTP_DEBUG_LOG=0

# 32-byte key (openssl rand -hex 32) — encrypts admin-managed secret settings at rest. Keep it in env (it decrypts the rest).
APP_VAULT_KEY=

# Shared secret for the subscription-renewal cron. The pixevel-cron.timer fires
# pixevel-cron.service daily, which curls /api/cron/subscriptions with header
# x-cron-secret=<this>. Must match the CRON_SECRET admin setting. Generate with:
#   openssl rand -hex 32
CRON_SECRET=
