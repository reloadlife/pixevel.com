# PostgreSQL connection string used by Drizzle (getDb) and drizzle-kit.
DATABASE_URL=postgresql://pixevel:pixevel_password@localhost:5434/pixevel

# Secret used to HMAC OTP codes. Set a long random value in production.
SESSION_SECRET=

# Comma-separated Iranian phone numbers that should be granted ADMIN on login.
PIXEVEL_ADMIN_PHONES=

# Kavenegar SMS OTP delivery.
KAVENEGAR_TOKEN=
KAVENEGAR_OTP_TEMPLATE=
KAVENEGAR_TIMEOUT_MS=

# Telegram login-OTP delivery.
TELEGRAM_LOGIN_OTP_BOT_TOKEN=
TELEGRAM_LOGIN_OTP_CHAT_ID=
TELEGRAM_LOGIN_OTP_TIMEOUT_MS=

# Telegram general notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Card-to-card payment method.
CARD_TO_CARD_NUMBER=
CARD_TO_CARD_HOLDER=

# Zarinpal payment gateway.
# Use the sandbox merchant ID for local development.
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000
# Set to "false" to use the production gateway (payment.zarinpal.com).
ZARINPAL_SANDBOX=true
# Public base URL of this app — used to build the Zarinpal callback_url.
APP_BASE_URL=http://localhost:4000
