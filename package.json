{
  "name": "pixevel-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0 <23 || >=24.0.0"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check --write",
    "db:up": "docker compose -f compose.dev.yaml up -d",
    "db:down": "docker compose -f compose.dev.yaml down",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "setup": "bun run db:push",
    "deploy": "bash deploy/deploy.sh",
    "deploy:dry": "bash deploy/deploy.sh --dry",
    "deploy:prepare": "bun run db:push && bun run build",
    "deploy:server": "bash scripts/deploy-server.sh",
    "db:seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^5.3.2",
    "sanitize-html": "^2.17.5",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.6"
  }
}
