# PostgreSQL connection string used by Drizzle (getDb) and drizzle-kit.
DATABASE_URL=postgresql://pixevel:pixevel_password@localhost:5434/pixevel

# Secret used to HMAC OTP codes. Set a long random value in production.
SESSION_SECRET=

# Comma-separated Iranian phone numbers that should be granted ADMIN on login.
PIXEVEL_ADMIN_PHONES=

# Kavenegar SMS OTP delivery.
KAVENEGAR_TOKEN=
KAVENEGAR_OTP_TEMPLATE=
KAVENEGAR_TIMEOUT_MS=

# Telegram login-OTP delivery.
TELEGRAM_LOGIN_OTP_BOT_TOKEN=
TELEGRAM_LOGIN_OTP_CHAT_ID=
TELEGRAM_LOGIN_OTP_TIMEOUT_MS=

# Telegram general notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Transactional email (Resend HTTP API). When unset, email sending is a no-op
# ("skipped") and never blocks checkout/payment — codes stay visible in account.
RESEND_API_KEY=
# From header, e.g. "Pixevel <no-reply@pixevel.com>".
EMAIL_FROM=
# Optional request timeout in ms (default 10000).
EMAIL_TIMEOUT_MS=

# Card-to-card payment method.
CARD_TO_CARD_NUMBER=
CARD_TO_CARD_HOLDER=

# Zarinpal payment gateway.
# Use the sandbox merchant ID for local development.
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000
# Set to "false" to use the production gateway (payment.zarinpal.com).
ZARINPAL_SANDBOX=true
# Public base URL of this app — used to build the Zarinpal callback_url.
APP_BASE_URL=http://localhost:4000

# ─── Payment gateways (optional; method disabled until set) ──────────────────
# Behpardakht (Mellat / BPM)
BEHPARDAKHT_TERMINAL_ID=
BEHPARDAKHT_USERNAME=
BEHPARDAKHT_PASSWORD=
# Saman (SEP)
SAMAN_TERMINAL_ID=
# SnappPay (installment)
SNAPPPAY_CLIENT_ID=
SNAPPPAY_CLIENT_SECRET=
SNAPPPAY_USERNAME=
SNAPPPAY_PASSWORD=
# DigiPay (installment)
DIGIPAY_CLIENT_ID=
DIGIPAY_CLIENT_SECRET=
DIGIPAY_USERNAME=
DIGIPAY_PASSWORD=

# ─── Domains (spaceship.com reseller; disabled until set) ────────────────────
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=
SPACESHIP_BASE_URL=https://spaceship.dev/api/v1
SPACESHIP_CONTACT_ID=
SPACESHIP_USD_TO_TOMAN=70000
DOMAIN_PRICE_MARKUP=1.2
DOMAIN_FALLBACK_PRICE_TOMAN=990000

# ─── VPS server provisioning (upstream; disabled until set) ──────────────────
SERVER_PROVIDER_API_URL=
SERVER_PROVIDER_API_KEY=
